// .vscode/launch.json
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Auction Server (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/lab3/q1/server",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/lab3/q1",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}