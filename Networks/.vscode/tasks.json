// .vscode/tasks.json
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build server",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "-O0",
                "${workspaceFolder}/lab3/q1/server.c",
                "-o",
                "${workspaceFolder}/lab3/q1/server"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the server executable"
        }
    ]
}