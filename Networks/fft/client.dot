digraph ReceiverFSM {
  rankdir=LR;
  node [shape=box];

  R_IDLE -> R_HDR_RECV [label="recv(FILE_HDR) / create file"];

  R_HDR_RECV -> R_WAIT_BLAST [label="send(FILE_HDR_ACK)"];
  R_WAIT_BLAST -> R_HDR_RECV [label="recv(FILE_HDR)"];
  R_WAIT_BLAST -> R_RECVING_BLAST [label="recv(BLAST_PKT) / buffer records"];

  R_RECVING_BLAST -> R_RECVING_BLAST [label="recv(BLAST_PKT) / buffer records"];
  R_RECVING_BLAST -> R_SEND_REC_MISS [label="recv(IS_BLAST_OVER)"];
  R_SEND_REC_MISS -> R_RECVING_BLAST [label="send(REC_MISS(list != {}))"];
  R_SEND_REC_MISS -> R_WAIT_DISCONNECT [label="send(REC_MISS({})) / final blast"];
  R_WAIT_DISCONNECT -> R_SEND_REC_MISS [label="recv(IS_BLAST_OVER)"];
  R_WAIT_DISCONNECT -> R_DONE [label="recv(DISCONNECT) or linger timeout"];
}

