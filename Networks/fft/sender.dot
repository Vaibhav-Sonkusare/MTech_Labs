digraph SenderFSM {
  rankdir=LR;
  node [shape=box];

  S_IDLE -> S_HDR_SENT [label="send(FILE_HDR)"];
  S_HDR_SENT -> S_IDLE [label="timeout(T_hdr)"];
  S_HDR_SENT -> S_SENDING_BLAST [label="recv(FILE_HDR_ACK)"];

  S_SENDING_BLAST -> S_SENDING_BLAST [label="send({(st rec1, end rec1), . . . , (st recN , end recN )}forN≥1)"];

  S_SENDING_BLAST -> S_WAIT_REC_MISS [label="send(IS_BLAST_OVER)"];

  S_WAIT_REC_MISS -> S_SENDING_BLAST [label="recv(REC_MISS(list != {}))"];
  S_WAIT_REC_MISS -> S_LAST_BLAST_DONE [label="recv(REC_MISS({}))"];
  S_WAIT_REC_MISS -> S_SENDING_BLAST [label="timeout(T_isblastover)"];

  S_LAST_BLAST_DONE -> S_DISCONNECT [label="send(DISCONNECT)"];
  S_LAST_BLAST_DONE -> S_SENDING_BLAST [label="send({(st rec1, end rec1), . . . , (st recN , end recN )}forN≥1)"];
  
  S_DISCONNECT -> S_LINGER [label="start linger timer"];
  S_LINGER -> S_DONE [label="linger timeout"];
}

